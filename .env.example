# Required for stable encrypted storage and signed login sessions.
PLAUDE_APP_SECRET=

# Required login credentials. Prefer HASH/SALT for deployments.
APP_LOGIN_ID=admin
APP_LOGIN_PASSWORD_HASH=
APP_LOGIN_PASSWORD_SALT=
# APP_LOGIN_PASSWORD=

# App URLs and Docker ports.
APP_BASE_URL=http://localhost:3000
APP_PORT=3000
# Optional. Auto-detected from the request by default; set true behind HTTPS
# if your proxy does not send X-Forwarded-Proto.
APP_AUTH_COOKIE_SECURE=

# STT provider keys. These may also be pasted in Settings instead.
OPENROUTER_API_KEY=
DEEPGRAM_API_KEY=
SONIOX_API_KEY=

# Transcription cleanup. If POSTPROCESS_BASE_URL is empty, cleanup uses OpenRouter.
POSTPROCESS_API_KEY=
# POSTPROCESS_BASE_URL=http://127.0.0.1:8317/v1
# POSTPROCESS_MODEL=gpt-5.3-codex-spark
CLEANUP_RECORDING_CONCURRENCY=2

# OpenClaw auto-send. These may also be set in Settings.
OPENCLAW_ENABLED=
OPENCLAW_WEBHOOK_URL=http://127.0.0.1:18789/hooks/agent
OPENCLAW_HOOK_TOKEN=
# OPENCLAW_MODEL=
# OPENCLAW_THINKING=
# OPENCLAW_DELIVER=false
# OPENCLAW_DELIVERY_CHANNEL=discord
# OPENCLAW_DELIVERY_TARGET=

# Plaud OAuth.
PLAUD_OAUTH_TOKEN_FILE=
PLAUD_OAUTH_REDIRECT_URI=
PLAUD_OAUTH_LOOPBACK_HOST=0.0.0.0
PLAUD_OAUTH_LOOPBACK_PORT=8199
PLAUD_OAUTH_API_BASE=https://platform.plaud.ai/developer/api
PLAUD_REFRESH_URL=https://platform.plaud.ai/developer/api/oauth/third-party/access-token/refresh
