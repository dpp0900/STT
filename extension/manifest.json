{
  "manifest_version": 3,
  "name": "Plaude STT Connector",
  "version": "0.1.0",
  "description": "Bridge a logged-in Plaud web session to the local Plaude STT app.",
  "minimum_chrome_version": "114",
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "https://web.plaud.ai/*",
    "https://api.plaud.ai/*",
    "https://api-euc1.plaud.ai/*",
    "https://api-apse1.plaud.ai/*",
    "https://api-apne1.plaud.ai/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Plaude STT Connector",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://web.plaud.ai/*"],
      "js": ["content-plaud.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["content-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-bridge.js"],
      "matches": ["http://localhost/*", "http://127.0.0.1/*"]
    }
  ]
}
